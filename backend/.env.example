# Banco de dados (RDS MySQL em produção, MySQL local em dev)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ecommerce
# Caminho do certificado CA (obrigatorio em producao, RDS exige SSL). Deixe vazio em dev local.
DB_SSL_CA=

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# SMTP (Gmail + Senha de App) - usado para e-mail de redefinicao de senha
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_APP_PASSWORD=senha-de-app-do-gmail
SMTP_FROM_NAME=KAMI CO. Ecommerce

# Frontend (usado para montar o link de reset de senha)
FRONTEND_URL=http://localhost:3000

# Integracao Tiny ERP (OAuth2 - app "Sistema Ecommerce" cadastrado em Configuracoes > Aplicativos API)
TINY_CLIENT_ID=tiny-api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TINY_CLIENT_SECRET=troque-pelo-client-secret-gerado-no-tiny
TINY_REDIRECT_URI=http://localhost:8000/api/integrations/tiny/oauth/callback

# Ambiente
ENVIRONMENT=development
